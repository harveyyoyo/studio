import { useState, useEffect } from 'react';
import { Card, CardContent, CardHeader, CardTitle, CardDescription } from '@/components/ui/card';
import { Label } from '@/components/ui/label';
import { Button } from '@/components/ui/button';
import { Table, TableBody, TableCell, TableHead, TableHeader, TableRow } from "@/components/ui/table";
import { Loader2, Clock, Trash2, Plus, Edit } from 'lucide-react';
import { useToast } from '@/hooks/use-toast';
import { useAppContext } from './AppProvider';
import { AttendanceClass, Teacher, Student, Class } from '@/lib/types';
import { AiScheduleImporter } from './AiScheduleImporter';
import { useSettings } from './providers/SettingsProvider';
import { cn, getStudentNickname } from '@/lib/utils';
import { useArcadeSound } from '@/hooks/useArcadeSound';
import { Dialog, DialogContent, DialogDescription, DialogHeader, DialogTitle, DialogTrigger } from '@/components/ui/dialog';
import { Input } from '@/components/ui/input';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';
import { ScrollArea } from '@/components/ui/scroll-area';
import { Checkbox } from '@/components/ui/checkbox';

interface AdminAttendanceManagerProps {
    teachers: Teacher[];
    students: Student[];
    schoolClasses: Class[];
}

export function AdminAttendanceManager({ teachers, students, schoolClasses }: AdminAttendanceManagerProps) {
    const { getAttendanceClasses, deleteAttendanceClass, addAttendanceClass, updateAttendanceClass } = useAppContext();
    const { toast } = useToast();
    const { settings } = useSettings();
    const playSound = useArcadeSound();
    const isGraphic = settings.graphicMode === 'graphics';
    
    const [classes, setClasses] = useState<AttendanceClass[]>([]);
    const [isLoading, setIsLoading] = useState(true);

    const loadClasses = async () => {
        if (!getAttendanceClasses) return;
        setIsLoading(true);
        try {
            const data = await getAttendanceClasses();
            setClasses(data);
        } catch (err: any) {
             toast({ variant: 'destructive', title: 'Error loading classes', description: err.message });
        } finally {
            setIsLoading(false);
        }
    };

    useEffect(() => {
        loadClasses();
    }, [getAttendanceClasses]);

    // --- FORM STATE FOR MANUAL CLASS ---
    const [isAddDialogOpen, setIsAddDialogOpen] = useState(false);
    const [editingClass, setEditingClass] = useState<AttendanceClass | null>(null);

    const [className, setClassName] = useState('');
    const [teacherId, setTeacherId] = useState('');
    const [studentIds, setStudentIds] = useState<string[]>([]);
    const [filterClassId, setFilterClassId] = useState<string>('all');
    const [pointsForSignIn, setPointsForSignIn] = useState(1);
    const [pointsForOnTime, setPointsForOnTime] = useState(1);
    const [onTimeWindowMinutes, setOnTimeWindowMinutes] = useState(15);
    const [startTime, setStartTime] = useState('08:00');
    const [endTime, setEndTime] = useState('08:45');

    const resetForm = () => {
        setClassName('');
        setTeacherId('');
        setStudentIds([]);
        setPointsForSignIn(1);
        setPointsForOnTime(1);
        setOnTimeWindowMinutes(15);
        setStartTime('08:00');
        setEndTime('08:45');
        setEditingClass(null);
    };

    const openEdit = (c: AttendanceClass) => {
        setEditingClass(c);
        setClassName(c.className || '');
        setTeacherId(c.teacherId || '');
        setStudentIds(c.studentIds || []);
        setPointsForSignIn(c.pointsForSignIn ?? 1);
        setPointsForOnTime(c.pointsForOnTime ?? 1);
        setOnTimeWindowMinutes(c.onTimeWindowMinutes ?? 15);
        setStartTime(c.startTime || '08:00');
        setEndTime(c.endTime || '08:45');
        setIsAddDialogOpen(true);
    };

    const handleSaveManual = async () => {
        if (!className.trim()) {
            toast({ variant: 'destructive', title: 'Name required.' });
            return;
        }
        if (!teacherId) {
            toast({ variant: 'destructive', title: 'Teacher required.' });
            return;
        }
        if (!addAttendanceClass || !updateAttendanceClass) return;

        const classData: Omit<AttendanceClass, 'id'> = {
            className: className.trim(),
            teacherId,
            studentIds,
            pointsForSignIn,
            pointsForOnTime,
            onTimeWindowMinutes,
            startTime,
            endTime,
        };

        try {
            if (editingClass) {
                await updateAttendanceClass({ ...classData, id: editingClass.id! });
                setClasses(classes.map(c => c.id === editingClass.id ? { ...classData, id: editingClass.id } : c));
                toast({ title: 'Class updated' });
            } else {
                const newClass = await addAttendanceClass(classData);
                if (newClass) setClasses([...classes, newClass]);
                toast({ title: 'Class created' });
            }
            playSound('success');
            setIsAddDialogOpen(false);
            resetForm();
        } catch (e: any) {
             toast({ variant: 'destructive', title: 'Error saving class', description: e.message });
        }
    };

    const toggleStudent = (studentId: string) => {
        setStudentIds(prev => 
            prev.includes(studentId) ? prev.filter(id => id !== studentId) : [...prev, studentId]
        );
    };

    const filteredStudents = [...(students || [])].filter(s => filterClassId === 'all' || s.classId === filterClassId).sort((a,b)=> a.lastName.localeCompare(b.lastName));

    const toggleSelectAllFiltered = () => {
        const filteredIds = filteredStudents.map(s => s.id);
        const allSelected = filteredIds.every(id => studentIds.includes(id));
        
        if (allSelected) {
            setStudentIds(prev => prev.filter(id => !filteredIds.includes(id)));
        } else {
            setStudentIds(prev => Array.from(new Set([...prev, ...filteredIds])));
        }
    };
    // -----------------------------------

    const handleDelete = async (id: string) => {
        if (!confirm("Are you sure you want to delete this configuration?")) return;
        if (!deleteAttendanceClass) return;
        try {
            await deleteAttendanceClass(id);
            setClasses(classes.filter(c => c.id !== id));
            playSound('error');
            toast({ title: 'Class deleted globally' });
        } catch (e: any) {
            toast({ variant: 'destructive', title: 'Error deleting class', description: e.message });
        }
    };

    const handleSaveAiClasses = async (newClasses: Partial<AttendanceClass>[]) => {
        if (!addAttendanceClass) return;
        try {
            const added = [];
            for (const c of newClasses) {
                // Ensure all required fields are there.
                if (c.className && c.teacherId && c.startTime && c.endTime) {
                   const result = await addAttendanceClass(c as Omit<AttendanceClass, 'id'>);
                   if (result) added.push(result);
                }
            }
            setClasses([...classes, ...added]);
            playSound('success');
            toast({ title: 'AI Schedule Imported', description: `Successfully created ${added.length} classes.` });
        } catch (error: any) {
            toast({ variant: 'destructive', title: 'Error saving classes', description: error.message });
        }
    };


    const getTeacherName = (tId: string) => {
        return teachers.find(t => t.id === tId)?.name || 'Unknown Teacher';
    };


    return (
        <Card className={cn("border-t-4", isGraphic ? "border-amber-400 bg-card/60 backdrop-blur-xl shadow-2xl" : "border-amber-500 shadow-md bg-white")}>
            <CardHeader className="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
                <div>
                   <CardTitle className="flex items-center gap-2 text-2xl font-black">
                        <div className={cn("p-2 rounded-xl", isGraphic ? 'bg-amber-400/20 text-amber-400' : 'bg-amber-100 text-amber-600')}>
                            <Clock className="w-6 h-6" />
                        </div>
                        Global Attendance Configurations
                   </CardTitle>
                   <CardDescription>
                        View all generated attendance classes. Use the AI Importer to rapidly ingest a master schedule.
                   </CardDescription>
                </div>
                <div className="flex gap-2">
                    <Dialog open={isAddDialogOpen} onOpenChange={(open) => { setIsAddDialogOpen(open); if (!open) resetForm(); }}>
                        <DialogTrigger asChild>
                            <Button className="bg-amber-500 hover:bg-amber-600 text-white font-black uppercase tracking-widest rounded-xl shadow-lg shadow-amber-200/50 active:scale-95 transition-all">
                                <Plus className="w-4 h-4 mr-2" /> Add Class
                            </Button>
                        </DialogTrigger>
                        <DialogContent className="sm:max-w-[600px] h-[90vh] flex flex-col rounded-3xl border-none shadow-2xl p-0">
                            <DialogHeader className="px-6 pt-6 pb-2 shrink-0">
                                <DialogTitle className="text-2xl font-black text-slate-800 dark:text-white">
                                    {editingClass ? 'Edit Attendance Class' : 'New Attendance Class'}
                                </DialogTitle>
                                <DialogDescription>
                                    Create an attendance configuration and assign a teacher.
                                </DialogDescription>
                            </DialogHeader>
                            <ScrollArea className="flex-grow px-6 pb-4">
                                <div className="space-y-6 pt-2 pb-6">
                                    <div className="grid grid-cols-2 gap-4">
                                        <div className="space-y-2">
                                            <Label className="text-[10px] font-black uppercase tracking-widest ml-1">Class Name</Label>
                                            <Input value={className} onChange={e => setClassName(e.target.value)} placeholder="e.g. 1st Period English" className="h-12 rounded-xl border-2 border-slate-100 bg-slate-50 font-bold text-slate-900" />
                                        </div>
                                        <div className="space-y-2">
                                            <Label className="text-[10px] font-black uppercase tracking-widest ml-1 text-primary">Assigned Teacher</Label>
                                            <Select value={teacherId} onValueChange={setTeacherId}>
                                                <SelectTrigger className={cn("h-12 rounded-xl border-2 bg-slate-50 font-bold", !teacherId ? "border-amber-200 bg-amber-50" : "border-slate-100")}>
                                                    <SelectValue placeholder="Select Teacher" />
                                                </SelectTrigger>
                                                <SelectContent>
                                                    {teachers.map(t => (
                                                        <SelectItem key={t.id} value={t.id}>{t.name}</SelectItem>
                                                    ))}
                                                </SelectContent>
                                            </Select>
                                        </div>
                                    </div>

                                    <div className="space-y-3">
                                        <div className="flex items-center justify-between mb-2">
                                            <Label className="text-[10px] font-black uppercase tracking-widest ml-1">Enrolled Students</Label>
                                            <div className="flex gap-2 items-center">
                                                <Select value={filterClassId} onValueChange={setFilterClassId}>
                                                    <SelectTrigger className="h-8 text-xs rounded-lg min-w-[120px]">
                                                        <SelectValue placeholder="Filter by class..." />
                                                    </SelectTrigger>
                                                    <SelectContent>
                                                        <SelectItem value="all">All Classes</SelectItem>
                                                        {schoolClasses?.map(c => (
                                                            <SelectItem key={c.id} value={c.id}>{c.name}</SelectItem>
                                                        ))}
                                                    </SelectContent>
                                                </Select>
                                                <Button type="button" variant="outline" size="sm" onClick={toggleSelectAllFiltered} className="h-8 text-[10px] uppercase font-bold tracking-widest px-2">
                                                    {filteredStudents.length > 0 && filteredStudents.every(s => studentIds.includes(s.id)) ? 'Deselect All' : 'Select All'}
                                                </Button>
                                            </div>
                                        </div>
                                        <p className="text-xs text-muted-foreground leading-tight">Select specific students to restrict who earns points in this class.</p>
                                        <div className="max-h-[160px] overflow-y-auto border-2 border-slate-100 rounded-xl bg-slate-50 p-2 space-y-1">
                                            {filteredStudents.map(s => (
                                                <div key={s.id} className="flex items-center gap-2 hover:bg-slate-100 p-1 rounded-lg">
                                                    <Checkbox
                                                        id={`admin-att-student-${s.id}`}
                                                        checked={studentIds.includes(s.id)}
                                                        onCheckedChange={() => toggleStudent(s.id)}
                                                    />
                                                    <Label htmlFor={`admin-att-student-${s.id}`} className="cursor-pointer text-sm font-semibold text-slate-800">{s.lastName}, {getStudentNickname(s)}</Label>
                                                </div>
                                            ))}
                                            {filteredStudents.length === 0 && <p className="text-xs text-center p-2 opacity-50 text-slate-600">No students available in this view</p>}
                                        </div>
                                        <p className="text-[10px] font-bold tracking-widest uppercase text-muted-foreground text-right">{studentIds.length} Selected</p>
                                    </div>

                                    <div className="grid grid-cols-2 gap-4 pt-4 border-t border-slate-100">
                                        <div className="space-y-2">
                                            <Label className="text-[10px] font-black uppercase tracking-widest ml-1">Start Time (24h)</Label>
                                            <Input type="time" value={startTime} onChange={e => setStartTime(e.target.value)} className="h-12 rounded-xl border-2 border-slate-100 bg-slate-50 font-mono text-lg font-bold" />
                                        </div>
                                        <div className="space-y-2">
                                            <Label className="text-[10px] font-black uppercase tracking-widest ml-1">End Time (24h)</Label>
                                            <Input type="time" value={endTime} onChange={e => setEndTime(e.target.value)} className="h-12 rounded-xl border-2 border-slate-100 bg-slate-50 font-mono text-lg font-bold" />
                                        </div>
                                    </div>
                                    
                                    <div className="pt-4 border-t border-slate-100 space-y-4">
                                        <Label className="text-[10px] font-black uppercase tracking-widest text-muted-foreground">Reward Points Configuration</Label>
                                        <div className="grid grid-cols-3 gap-4">
                                             <div className="space-y-2 bg-slate-50 p-3 rounded-xl border border-slate-100 text-center">
                                                <Label className="text-[10px] font-black uppercase tracking-widest text-slate-500">Sign In Points</Label>
                                                <Input type="number" min="0" value={pointsForSignIn} onChange={e => setPointsForSignIn(Number(e.target.value))} className="h-10 text-center font-black text-lg bg-white border-slate-200" />
                                            </div>
                                            <div className="space-y-2 bg-slate-50 p-3 rounded-xl border border-slate-100 text-center">
                                                <Label className="text-[10px] font-black uppercase tracking-widest text-slate-500">On Time Bonus</Label>
                                                <Input type="number" min="0" value={pointsForOnTime} onChange={e => setPointsForOnTime(Number(e.target.value))} className="h-10 text-center font-black text-lg bg-white border-slate-200" />
                                            </div>
                                            <div className="space-y-2 bg-slate-50 p-3 rounded-xl border border-slate-100 text-center">
                                                <Label className="text-[10px] font-black uppercase tracking-widest text-slate-500">On Time Window</Label>
                                                <div className="relative">
                                                     <Input type="number" min="0" value={onTimeWindowMinutes} onChange={e => setOnTimeWindowMinutes(Number(e.target.value))} className="h-10 text-center font-black text-lg bg-white border-slate-200 pr-8" />
                                                     <span className="absolute right-3 top-1/2 -translate-y-1/2 text-xs font-bold text-slate-400">min</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </ScrollArea>
                            <div className="p-4 border-t bg-slate-50/50 mt-auto shrink-0 flex gap-2">
                                <Button className="w-full h-12 bg-amber-500 hover:bg-amber-600 text-white font-black uppercase tracking-widest rounded-xl shadow-lg shadow-amber-200" onClick={handleSaveManual}>
                                    {editingClass ? 'Save Changes' : 'Create Class'}
                                </Button>
                            </div>
                        </DialogContent>
                    </Dialog>
                    <AiScheduleImporter teachers={teachers} onSaveAll={handleSaveAiClasses} />
                </div>
            </CardHeader>
            <CardContent>
                {isLoading ? (
                    <div className="py-20 flex justify-center items-center">
                        <Loader2 className="w-8 h-8 animate-spin text-muted-foreground mr-3" />
                        <span className="font-bold text-muted-foreground uppercase tracking-widest">Loading Classes...</span>
                    </div>
                ) : classes.length === 0 ? (
                    <div className="py-20 flex flex-col items-center justify-center text-center opacity-50">
                        <Clock className="w-16 h-16 mb-4" />
                        <Label className="uppercase font-black tracking-widest text-lg">No Attendance Classes</Label>
                        <p className="max-w-md mt-2">No teachers have set up attendance, or the global schedule is empty. Try importing a schedule with AI.</p>
                    </div>
                ) : (
                    <div className="rounded-xl border border-border/50 overflow-hidden bg-background/50">
                        <Table>
                            <TableHeader className={isGraphic ? "bg-muted/30" : "bg-slate-50"}>
                                <TableRow>
                                    <TableHead className="font-black uppercase text-[10px] tracking-widest">Class Name</TableHead>
                                    <TableHead className="font-black uppercase text-[10px] tracking-widest">Teacher</TableHead>
                                    <TableHead className="font-black uppercase text-[10px] tracking-widest">Time</TableHead>
                                    <TableHead className="font-black uppercase text-[10px] tracking-widest text-right">Actions</TableHead>
                                </TableRow>
                            </TableHeader>
                            <TableBody>
                                {classes.sort((a,b) => a.startTime.localeCompare(b.startTime)).map((c) => (
                                    <TableRow key={c.id}>
                                        <TableCell className="font-bold">{c.className}</TableCell>
                                        <TableCell>{getTeacherName(c.teacherId)}</TableCell>
                                        <TableCell className="font-mono text-sm">{c.startTime} - {c.endTime}</TableCell>
                                        <TableCell className="text-right">
                                            <Button variant="ghost" size="icon" onClick={() => openEdit(c)} className="text-muted-foreground hover:bg-primary/10 hover:text-primary transition-colors">
                                                <Edit className="w-4 h-4" />
                                            </Button>
                                            <Button variant="ghost" size="icon" onClick={() => handleDelete(c.id!)} className="text-muted-foreground hover:bg-destructive/10 hover:text-destructive transition-colors">
                                                <Trash2 className="w-4 h-4" />
                                            </Button>
                                        </TableCell>
                                    </TableRow>
                                ))}
                            </TableBody>
                        </Table>
                    </div>
                )}
            </CardContent>
        </Card>
    );
}

