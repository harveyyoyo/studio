import { useState } from 'react';
import { Button } from '@/components/ui/button';
import { Card, CardContent, CardHeader, CardTitle, CardDescription } from '@/components/ui/card';
import { Label } from '@/components/ui/label';
import { Input } from '@/components/ui/input';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';
import { ScrollArea } from '@/components/ui/scroll-area';
import { Loader2, Trash2, Wand2, Calendar, Plus, Save } from 'lucide-react';
import { useToast } from '@/hooks/use-toast';
import { AttendanceClass, Teacher } from '@/lib/types';
import { useSettings } from './providers/SettingsProvider';
import { cn } from '@/lib/utils';
import { Dialog, DialogContent, DialogDescription, DialogHeader, DialogTitle, DialogTrigger } from '@/components/ui/dialog';

interface AiScheduleImporterProps {
    teachers: Teacher[];
    onSaveAll: (classes: Partial<AttendanceClass>[]) => Promise<void>;
}

export function AiScheduleImporter({ teachers, onSaveAll }: AiScheduleImporterProps) {
    const [isOpen, setIsOpen] = useState(false);
    const [rawText, setRawText] = useState('');
    const [isParsing, setIsParsing] = useState(false);
    const [parsedClasses, setParsedClasses] = useState<Partial<AttendanceClass>[]>([]);
    const [isSaving, setIsSaving] = useState(false);
    const { toast } = useToast();
    const { settings } = useSettings();
    const isGraphic = settings.graphicMode === 'graphics';

    const handleParse = async () => {
        if (!rawText.trim()) return;
        setIsParsing(true);
        try {
            const res = await fetch('/api/parse-schedule', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ prompt: rawText, model: localStorage.getItem('arcade_ai_model') || 'gemini-2.5-flash' })
            });
            if (!res.ok) throw new Error('Failed to parse schedule');
            const data = await res.json();
            
            // Map the parsed JSON to Partial<AttendanceClass>
            const mapped = data.map((c: any) => ({
                className: c.className || 'Unnamed Class',
                startTime: c.startTime || '08:00',
                endTime: c.endTime || '08:45',
                studentIds: [], // Start empty
                pointsForSignIn: 1,
                pointsForOnTime: 1,
                onTimeWindowMinutes: 15,
                teacherId: '' // Needs to be assigned
            }));
            
            setParsedClasses(mapped);
            if (mapped.length === 0) {
                 toast({ title: 'No classes found', description: 'Could not extract any classes from the provided text.' });
            } else {
                 toast({ title: 'Schedule Parsed', description: `Successfully extracted ${mapped.length} classes. Please assign teachers before saving.` });
            }
        } catch (error: any) {
            toast({ variant: 'destructive', title: 'Error processing schedule', description: error.message });
        } finally {
            setIsParsing(false);
        }
    };

    const updateParsedClass = (index: number, updates: Partial<AttendanceClass>) => {
        const newClasses = [...parsedClasses];
        newClasses[index] = { ...newClasses[index], ...updates };
        setParsedClasses(newClasses);
    };

    const removeParsedClass = (index: number) => {
        setParsedClasses(parsedClasses.filter((_, i) => i !== index));
    };

    const handleSaveAll = async () => {
        // Validate
        const missingTeachers = parsedClasses.some(c => !c.teacherId);
        if (missingTeachers) {
            toast({ variant: 'destructive', title: 'Missing Information', description: 'Please assign a teacher to all generated classes before saving.' });
            return;
        }

        setIsSaving(true);
        try {
            await onSaveAll(parsedClasses);
            setIsOpen(false);
            setRawText('');
            setParsedClasses([]);
        } finally {
            setIsSaving(false);
        }
    };

    return (
        <Dialog open={isOpen} onOpenChange={setIsOpen}>
            <DialogTrigger asChild>
                <Button className="font-bold uppercase tracking-widest gap-2" variant={isGraphic ? 'secondary' : 'default'}>
                    <Wand2 className="w-4 h-4" /> Import w/ AI
                </Button>
            </DialogTrigger>
            <DialogContent className={cn("sm:max-w-[800px] h-[85vh] flex flex-col p-0 overflow-hidden", isGraphic ? 'bg-card/95 backdrop-blur-2xl border-primary/20' : 'bg-white')}>
                <DialogHeader className="px-6 pt-6 pb-2 shrink-0">
                    <DialogTitle className="text-2xl font-black flex items-center gap-2">
                        <Wand2 className="w-6 h-6 text-primary" /> AI Schedule Importer
                    </DialogTitle>
                    <DialogDescription>
                        Paste your raw class schedule text (e.g., from an email or document) and let AI extract the classes and times.
                    </DialogDescription>
                </DialogHeader>
                <div className="flex-grow flex flex-col md:flex-row divide-y md:divide-y-0 md:divide-x overflow-hidden border-t">
                    {/* Left: Input Sidebar */}
                    <div className="md:w-1/3 flex flex-col bg-slate-50/50 dark:bg-black/20 p-4 shrink-0">
                        <Label className="text-xs font-bold uppercase tracking-widest text-muted-foreground mb-2">Raw Text</Label>
                        <textarea 
                            className="flex-grow w-full rounded-xl border border-input bg-background p-3 text-sm resize-none focus:outline-none focus:ring-2 focus:ring-primary"
                            placeholder="e.g. 8:00am - 8:45am: Reading Block with Mr. Smith \n 8:50 - 9:30: Math..."
                            value={rawText}
                            onChange={e => setRawText(e.target.value)}
                        />
                        <Button 
                            className="w-full mt-4 font-bold" 
                            onClick={handleParse} 
                            disabled={isParsing || !rawText.trim()}
                        >
                            {isParsing ? <Loader2 className="w-4 h-4 mr-2 animate-spin" /> : <Wand2 className="w-4 h-4 mr-2" />}
                            Process Text
                        </Button>
                    </div>

                    {/* Right: Parsed Results */}
                    <div className="md:w-2/3 flex flex-col shrink-0 min-h-0">
                         <div className="px-4 py-3 border-b bg-muted/30 flex justify-between items-center shrink-0">
                            <Label className="font-black text-xs uppercase tracking-widest">
                                Parsed Classes ({parsedClasses.length})
                            </Label>
                            {parsedClasses.length > 0 && (
                                <Button size="sm" onClick={handleSaveAll} disabled={isSaving} className="gap-2 font-bold h-8">
                                    {isSaving ? <Loader2 className="w-3 h-3 animate-spin" /> : <Save className="w-3 h-3" />}
                                    Save All to Database
                                </Button>
                            )}
                        </div>
                        <ScrollArea className="flex-grow p-4">
                            {parsedClasses.length === 0 ? (
                                <div className="h-full flex flex-col items-center justify-center opacity-40 py-20">
                                    <Calendar className="w-12 h-12 mb-4" />
                                    <p className="text-sm font-bold text-center px-8">Generated classes will appear here for review and teacher assignment.</p>
                                </div>
                            ) : (
                                <div className="space-y-4">
                                    {parsedClasses.map((c, i) => (
                                        <Card key={i} className="shadow-sm">
                                            <CardContent className="p-4 flex flex-col gap-3 relative">
                                                <Button variant="ghost" size="icon" className="absolute top-2 right-2 h-6 w-6 text-muted-foreground hover:text-destructive" onClick={() => removeParsedClass(i)}>
                                                    <Trash2 className="w-3 h-3" />
                                                </Button>
                                                <div className="grid grid-cols-2 gap-3 pr-6">
                                                     <div className="space-y-1 col-span-2">
                                                        <Label className="text-[10px] font-bold uppercase tracking-widest">Class Name</Label>
                                                        <Input className="h-8 font-bold" value={c.className || ''} onChange={e => updateParsedClass(i, { className: e.target.value })} />
                                                     </div>
                                                     <div className="space-y-1">
                                                        <Label className="text-[10px] font-bold uppercase tracking-widest">Start Time</Label>
                                                        <Input className="h-8 font-mono text-sm" value={c.startTime || ''} onChange={e => updateParsedClass(i, { startTime: e.target.value })} />
                                                     </div>
                                                     <div className="space-y-1">
                                                        <Label className="text-[10px] font-bold uppercase tracking-widest">End Time</Label>
                                                        <Input className="h-8 font-mono text-sm" value={c.endTime || ''} onChange={e => updateParsedClass(i, { endTime: e.target.value })} />
                                                     </div>
                                                     <div className="space-y-1 col-span-2 mt-1 pt-3 border-t">
                                                        <Label className="text-[10px] font-bold uppercase tracking-widest text-primary flex items-center gap-1">
                                                            Assign Teacher <span className="text-destructive">*</span>
                                                        </Label>
                                                        <Select value={c.teacherId || ''} onValueChange={v => updateParsedClass(i, { teacherId: v })}>
                                                            <SelectTrigger className={cn("h-9 border-primary/30", !c.teacherId && "bg-destructive/10 border-destructive/30")}>
                                                                <SelectValue placeholder="Select Teacher..." />
                                                            </SelectTrigger>
                                                            <SelectContent>
                                                                {teachers.map(t => (
                                                                    <SelectItem key={t.id} value={t.id}>{t.name}</SelectItem>
                                                                ))}
                                                            </SelectContent>
                                                        </Select>
                                                     </div>
                                                </div>
                                            </CardContent>
                                        </Card>
                                    ))}
                                </div>
                            )}
                        </ScrollArea>
                    </div>
                </div>
            </DialogContent>
        </Dialog>
    );
}

