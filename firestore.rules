
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuth() {
      return request.auth != null;
    }
    
    function isAdmin(schoolId) {
      return isAuth() && exists(/databases/$(database)/documents/schools/$(schoolId)/roles_admin/$(request.auth.uid));
    }
    
    // School document: any auth user can read (needed for passcode login flow)
    // and create (for sample school seeding). Only admins can modify or delete.
    match /schools/{schoolId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAdmin(schoolId);
      
      // Everything below is scoped to admins of THIS school only.
      // The school login flow creates roles_admin/{uid} on successful passcode,
      // so kiosk and redemption sessions already have admin status.

      match /students/{studentId} {
        allow read, write: if isAdmin(schoolId);

        match /activities/{activityId} {
          allow read, write: if isAdmin(schoolId);
        }
      }
      
      match /teachers/{teacherId} {
        allow read, write: if isAdmin(schoolId);
      }
      
      match /classes/{classId} {
        allow read, write: if isAdmin(schoolId);
      }
      
      match /categories/{categoryId} {
        allow read, write: if isAdmin(schoolId);
      }

      match /prizes/{prizeId} {
        allow read, write: if isAdmin(schoolId);
      }
      
      match /coupons/{couponId} {
        allow read, write: if isAdmin(schoolId);
      }
      
      // A user can grant themselves admin by creating their own uid doc
      // (happens during passcode login). Only existing admins can manage others.
      match /roles_admin/{uid} {
        allow read, update, delete: if isAdmin(schoolId);
        allow create: if isAuth() && request.auth.uid == uid;
      }

      // Passcode stored here; only writable by admins, never readable by clients.
      // The Cloud Function verifySchoolPasscode reads this via the admin SDK.
      match /secrets/{docId} {
        allow read: if false;
        allow write: if isAdmin(schoolId);
      }

      match /backups/{backupId} {
        allow read, write: if isAdmin(schoolId);
      }
    }
  }
}
