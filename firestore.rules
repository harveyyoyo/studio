
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuth() {
      return request.auth != null;
    }
    
    function isAdmin(schoolId) {
      let rolesPath = /databases/$(database)/documents/schools/$(schoolId)/roles_admin/$(request.auth.uid);
      let roleDocData = get(rolesPath).data;
      // This is a safer check. It ensures roleDocData is not null before trying to access .role
      return isAuth() && roleDocData != null && roleDocData.role == 'admin';
    }

    function isDeveloper() {
      return isAuth() && exists(/databases/$(database)/documents/appConfig/global)
        && 'developerUids' in get(/databases/$(database)/documents/appConfig/global).data
        && request.auth.uid in get(/databases/$(database)/documents/appConfig/global).data.developerUids;
    }

    // Global app configuration (e.g. app logo, name, tagline)
    match /appConfig/{docId} {
      // Public read so login page can show app logo before user signs in.
      allow read: if true;
      allow write: if false;
    }
    
    match /schools/{schoolId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAdmin(schoolId);

      // Read: any authenticated user (access control enforced at the
      // application layer via passcode — the school URL + passcode gate
      // prevents unauthorized UI access).
      // Write: only provisioned admins.

      match /students/{studentId} {
        allow read: if isAdmin(schoolId);
        allow write: if isAdmin(schoolId);

        match /activities/{activityId} {
          allow read: if isAdmin(schoolId);
          allow write: if isAdmin(schoolId);
        }
      }
      
      match /teachers/{teacherId} {
        allow read: if isAdmin(schoolId);
        allow write: if isAdmin(schoolId);
      }
      
      match /classes/{classId} {
        allow read: if isAdmin(schoolId);
        allow write: if isAdmin(schoolId);
      }
      
      match /categories/{categoryId} {
        allow read: if isAdmin(schoolId);
        allow write: if isAdmin(schoolId);
      }

      match /achievements/{achievementId} {
        allow read: if isAdmin(schoolId);
        allow write: if isAdmin(schoolId);
      }

      match /badges/{badgeId} {
        // Read: any authenticated user (so teachers/students can load badge definitions and earned badges).
        allow read: if request.auth != null;
        allow write: if isAdmin(schoolId);
      }

      match /prizes/{prizeId} {
        allow read: if isAdmin(schoolId);
        allow write: if isAdmin(schoolId);
      }
      
      match /coupons/{couponId} {
        allow read: if isAdmin(schoolId);
        allow write: if isAdmin(schoolId);
      }
      
      match /roles_admin/{uid} {
        // Admin roles are provisioned ONLY by trusted backend code (Admin SDK).
        // Clients may read their own role doc to confirm access after login.
        allow read: if isAuth() && request.auth.uid == uid;
        allow write: if false;
      }

      match /roles_teacher/{uid} {
        allow read: if isAuth() && request.auth.uid == uid;
        allow write: if false;
      }

      // Passcode stored here; never readable by clients.
      // The Cloud Function verifySchoolPasscode reads this via the admin SDK.
      match /secrets/{docId} {
        allow read: if false;
        allow write: if isAdmin(schoolId);
      }

      match /backups/{backupId} {
        allow read: if isAdmin(schoolId);
        allow write: if isAdmin(schoolId);
      }

      match /attendance/{docId} {
        allow read: if isAuth();
        allow write: if isAdmin(schoolId) || isDeveloper();
      }

      match /attendanceLog/{entryId} {
        allow read: if isAdmin(schoolId);
        allow create: if isAuth();
        allow update, delete: if isAdmin(schoolId);
      }
    }
  }
}
