
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuth() {
      return request.auth != null;
    }
    
    function isAdmin(schoolId) {
      return isAuth() && exists(/databases/$(database)/documents/schools/$(schoolId)/roles_admin/$(request.auth.uid));
    }
    
    // School metadata document
    match /schools/{schoolId} {
      allow read: if isAuth();
      allow write: if isAdmin(schoolId);
      
      // Students: admins have full control. Authenticated users can only update
      // specific fields on student docs (points, lifetimePoints, categoryPoints)
      // via transactional coupon/prize redemption. They cannot create or delete students.
      match /students/{studentId} {
        allow read: if isAuth();
        allow create, delete: if isAdmin(schoolId);
        allow update: if isAdmin(schoolId)
          || (isAuth() && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['points', 'lifetimePoints', 'categoryPoints']));
        
        // Activity logs: any authenticated user can read or create (for redemptions).
        // Only admins can update or delete activity records.
        match /activities/{activityId} {
          allow read: if isAuth();
          allow create: if isAuth();
          allow update, delete: if isAdmin(schoolId);
        }
      }
      
      // Teachers and Classes can only be managed by admins, but read by any authenticated user.
      match /teachers/{teacherId} {
        allow read: if isAuth();
        allow write: if isAdmin(schoolId);
      }
      
      match /classes/{classId} {
        allow read: if isAuth();
        allow write: if isAdmin(schoolId);
      }
      
      // Categories can only be managed by admins, but read by any authenticated user.
      match /categories/{categoryId} {
        allow read: if isAuth();
        allow write: if isAdmin(schoolId);
      }

      // Prizes (Reward Items) can only be managed by admins, but read by any authenticated user.
      match /prizes/{prizeId} {
          allow read: if isAuth();
          allow write: if isAdmin(schoolId);
      }
      
      // Coupons: admins can create/delete. Any authenticated user can read or update
      // (to mark a coupon as redeemed), but only specific fields are allowed on update.
      match /coupons/{couponId} {
        allow read: if isAuth();
        allow create: if isAdmin(schoolId);
        allow update: if isAuth()
          && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['used', 'usedAt', 'usedBy']);
        allow delete: if isAdmin(schoolId);
      }
      
      // Admin roles can be created by the user themselves upon login.
      // Only existing admins can read, update, or delete other admin roles.
      match /roles_admin/{uid} {
        allow read, update, delete: if isAdmin(schoolId);
        allow create: if isAuth() && request.auth.uid == uid;
      }

      // Backups subcollection
      match /backups/{backupId} {
        allow read, write: if isAdmin(schoolId);
      }
    }
  }
}
