/**
 * Firebase Security Rules for the Arcade Rewards Hub
 *
 * Core Philosophy:
 * This ruleset enforces a multi-tenant security model where all data is strictly
 * segregated by school. Access within a school is governed by three distinct
 * roles: Admins, Teachers, and Students. Admins have full control over their
 * school's data. Teachers can manage the students assigned to them. Students
 * can only access and manage their own personal data.
 *
 * Data Structure:
 * All data is nested under the top-level `/schools/{schoolId}` collection,
 * which acts as a hard security boundary between different schools. There are
 * no cross-school data access permissions.
 *
 * Key Security Decisions:
 * - Admin Access: A user is granted admin privileges for a specific school if
 *   a document with their UID exists in the `/schools/{schoolId}/roles_admin`
 *   collection. Only existing admins can grant admin rights to others.
 * - Teacher Access: A teacher's access is scoped to students who have a matching
 *   `teacherId` field in their student document.
 * - Student Access: A student's access is limited to their own document tree,
 *   verified by matching the `authUid` field in their student document with
 *   their authenticated UID.
 * - Public Data: Collections like `rewardItems` and `categories` are readable
 *   by any authenticated user within the school but are only writable by admins.
 * - User Listing: Listing of users (students or teachers) is restricted to
 *   Admins and, in the case of students, their assigned Teachers. Students
 *   cannot list other users.
 *
 * Denormalization for Authorization:
 * These rules rely heavily on denormalization to be fast and cost-effective.
 * Critical authorization data, such as a student's `authUid` or an assigned
 * `teacherId`, is stored directly on the documents being secured. This avoids
 * slow, expensive, or impossible cross-collection `get()` calls in rules,
 * particularly for list operations. For example, a teacher can query their
 * students' activities because the `teacherId` is denormalized onto each
 * activity document.
 *
 * Structural Segregation:
 * The multi-tenant structure `/schools/{schoolId}` is the primary form of
 * segregation. Within a school, role-based access control and ownership checks
 * on documents provide the necessary segregation between private user data and
 * shared school-wide data.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // Helper Functions
    // =====================================================================

    /**
     * Returns true if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Returns true if a document already exists.
     * Used to protect against updates/deletes on non-existent documents.
     */
    function isExistingDocument() {
      return resource != null;
    }

    /**
     * Checks if the currently authenticated user is an admin for the given school.
     * This is determined by the existence of a document with their UID in the
     * school's admin roles collection.
     */
    function isAdmin(schoolId) {
      return exists(/databases/$(database)/documents/schools/$(schoolId)/roles_admin/$(request.auth.uid));
    }

    /**
     * Checks if a user is a registered teacher in the given school.
     * This is determined by the existence of their teacher profile document.
     */
    function isTeacher(schoolId, uid) {
      return exists(/databases/$(database)/documents/schools/$(schoolId)/teachers/$(uid));
    }

    /**
     * A simple ownership check. Returns true if the request's auth UID
     * matches the provided UID.
     */
    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    /**
     * Retrieves a student's document for use in other helper functions.
     */
    function getStudentDoc(schoolId, studentId) {
      return get(/databases/$(database)/documents/schools/$(schoolId)/students/$(studentId));
    }

    /**
     * Checks if the authenticated user is the student associated with the document.
     * This requires a 'get' because the student document ID may not be the auth UID.
     */
    function isStudentSelf(schoolId, studentId) {
      return getStudentDoc(schoolId, studentId).data.authUid == request.auth.uid;
    }

    /**
     * Checks if the authenticated user is the teacher assigned to the student.
     */
    function isAssignedTeacher(schoolId, studentId) {
      return getStudentDoc(schoolId, studentId).data.teacherId == request.auth.uid;
    }

    /**
     * Verifies that the user redeeming a coupon is the student being credited.
     * Compares the user's auth UID against the authUid of the student document
     * referenced in the coupon update.
     */
    function isRedeemingStudent(schoolId) {
      return get(/databases/$(database)/documents/schools/$(schoolId)/students/$(request.resource.data.redeemedByStudentId)).data.authUid == request.auth.uid;
    }

    // =====================================================================
    // Rules
    // =====================================================================

    match /schools/{schoolId} {
      // The school document itself is a container and should not be directly mutable.
      allow read, write: if false;

      /**
       * @description Admin roles control access to a school's data. Only existing admins can manage this list.
       * @path /schools/{schoolId}/roles_admin/{adminUid}
       * @allow (create): An existing admin adds another user 'user123' as an admin.
       * @deny (create): A non-admin user tries to make themselves an admin.
       * @principle Prevents privilege escalation by ensuring only existing admins can grant admin rights.
       */
      match /roles_admin/{adminUid} {
        allow get: if isAdmin(schoolId);
        allow list: if isAdmin(schoolId);
        allow create: if isAdmin(schoolId);
        allow update: if isAdmin(schoolId);
        allow delete: if isAdmin(schoolId);
      }

      /**
       * @description Teacher profiles, managed by Admins. Teachers can view their own profile.
       * @path /schools/{schoolId}/teachers/{teacherId}
       * @allow (get): A teacher with auth UID 'teacher-abc' reads their own document at /teachers/teacher-abc.
       * @deny (update): A teacher tries to update another teacher's profile.
       * @deny (create): A user tries to create their own teacher profile.
       * @principle Enforces Admin-only provisioning and self-read access for teachers.
       */
      match /teachers/{teacherId} {
        allow get: if isAdmin(schoolId) || isOwner(teacherId);
        allow list: if isAdmin(schoolId);
        allow create: if isAdmin(schoolId);
        allow update: if isExistingDocument() && (isAdmin(schoolId) || isOwner(teacherId));
        allow delete: if isExistingDocument() && isAdmin(schoolId);
      }

      /**
       * @description Student profiles. Managed by Admins and assigned Teachers. Students can read their own data.
       * @path /schools/{schoolId}/students/{studentId}
       * @allow (get): A student reads their own profile document.
       * @allow (list): A teacher lists all students assigned to them (client must query by teacherId).
       * @deny (list): A student tries to list all other students.
       * @principle Segregates student data, allowing access only to the student, their teacher, or an admin.
       */
      match /students/{studentId} {
        allow get: if isStudentSelf(schoolId, studentId) || isAssignedTeacher(schoolId, studentId) || isAdmin(schoolId);
        allow list: if isAdmin(schoolId) || isTeacher(schoolId, request.auth.uid);
        allow create: if isAdmin(schoolId);
        allow update: if isExistingDocument() && (isStudentSelf(schoolId, studentId) || isAssignedTeacher(schoolId, studentId) || isAdmin(schoolId));
        allow delete: if isExistingDocument() && isAdmin(schoolId);

        /**
         * @description A student's activity log. Readable by the student and their teacher. Immutable once created.
         * @path /schools/{schoolId}/students/{studentId}/activities/{activityId}
         * @allow (create): A student adds a new activity record to their own log (e.g., redeeming a reward).
         * @deny (update): Anyone tries to change a historical activity record, except an admin.
         * @principle Ensures the integrity of historical data by making activity logs write-once for non-admins.
         */
        match /activities/{activityId} {
          allow get: if isStudentSelf(schoolId, studentId) || isAssignedTeacher(schoolId, studentId) || isAdmin(schoolId);
          allow list: if isStudentSelf(schoolId, studentId) || isAssignedTeacher(schoolId, studentId) || isAdmin(schoolId);
          allow create: if (isStudentSelf(schoolId, studentId) || isAssignedTeacher(schoolId, studentId) || isAdmin(schoolId)) && request.resource.data.studentId == studentId;
          allow update: if isExistingDocument() && isAdmin(schoolId);
          allow delete: if isExistingDocument() && isAdmin(schoolId);
        }
      }

      /**
       * @description Reward items for the school store. Publicly readable, admin-managed.
       * @path /schools/{schoolId}/rewardItems/{rewardItemId}
       * @allow (list): Any authenticated user (student/teacher) can list all available rewards.
       * @deny (create): A teacher or student tries to add a new reward item.
       * @principle Implements a public-read, admin-write pattern for shared school resources.
       */
      match /rewardItems/{rewardItemId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if isAdmin(schoolId);
        allow update: if isAdmin(schoolId);
        allow delete: if isAdmin(schoolId);
      }

      /**
       * @description Coupon categories. Publicly readable, admin-managed.
       * @path /schools/{schoolId}/categories/{categoryId}
       * @allow (list): Any authenticated user (student/teacher) can list all categories for UI dropdowns.
       * @deny (create): A teacher or student tries to add a new category.
       * @principle Implements a public-read, admin-write pattern for shared school resources.
       */
      match /categories/{categoryId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if isAdmin(schoolId);
        allow update: if isAdmin(schoolId);
        allow delete: if isAdmin(schoolId);
      }

      /**
       * @description Coupons created by teachers. Students can update them once to redeem them.
       * @path /schools/{schoolId}/coupons/{couponId}
       * @allow (create): A teacher creates a new coupon for their students, setting their own ID as teacherId.
       * @allow (update): A student redeems an unused coupon, marking it as 'used'.
       * @deny (delete): A student tries to delete a coupon.
       * @deny (update): A student tries to redeem a coupon that is already used.
       * @principle Manages the coupon lifecycle: teacher creation, student redemption, and restricted deletion.
       */
      match /coupons/{couponId} {
        allow get: if isSignedIn();
        allow list: if isAdmin(schoolId) || isTeacher(schoolId, request.auth.uid);
        allow create: if isAdmin(schoolId) || (isTeacher(schoolId, request.auth.uid) && request.resource.data.teacherId == request.auth.uid);
        allow update: if isExistingDocument() && (isAdmin(schoolId) || (resource.data.used == false && isRedeemingStudent(schoolId)));
        allow delete: if isExistingDocument() && (isAdmin(schoolId) || isOwner(resource.data.teacherId));
      }
    }
  }
}