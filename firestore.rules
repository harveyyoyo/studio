'rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Deny all access by default.
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow a user to read and write to their own school's data.
    match /schools/{schoolId} {
      allow read, write: if request.auth != null && request.auth.token.schoolId == schoolId;

      // Allow a user to read their own school's backups.
      match /backups/{backupId} {
        allow read: if request.auth != null && request.auth.token.schoolId == schoolId;
        allow write: if false; // Disallow writing to backups from the client.
      }
    }
  }
}
'