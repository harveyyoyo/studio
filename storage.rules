rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /school-logos/{schoolId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /backups/{allPaths=**} {
      // Backups are managed exclusively through Cloud Functions (admin SDK).
      // No direct client access is needed or permitted.
      allow read, write: if false;
    }
  }
}
